{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "*.ps1",
      "*.csv",
      "*.xlsx",
      "*.json",
      ".claude"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma",        "value": "no-cache" },
          { "key": "Expires",       "value": "0" }
        ]
      }
    ]
  }
}
